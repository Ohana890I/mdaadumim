rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Recommended: set this via Firebase Auth custom claims.
    // Example: request.auth.token.admin == true
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(data, allowed) {
      return data.keys().hasOnly(allowed);
    }

    function userCreateShapeValid() {
      return hasOnlyKeys(request.resource.data, [
        'fullName',
        'username',
        'password',
        'role',
        'approved',
        'blocked',
        'deletionRequested',
        'createdAt',
        'uid'
      ])
      && request.resource.data.fullName is string
      && request.resource.data.username is string
      && request.resource.data.password is string
      && request.resource.data.role is string
      && request.resource.data.approved is bool
      && request.resource.data.createdAt != null
      && request.resource.data.uid == request.auth.uid;
    }

    function userSelfUpdateShapeValid() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'fullName',
        'username',
        'password',
        'deletionRequested',
        'deletionRequestedAt'
      ]);
    }

    function availabilityShapeValid() {
      return hasOnlyKeys(request.resource.data, [
        'userId',
        'fullName',
        'role',
        'availability',
        'notes',
        'weekId',
        'submittedAt',
        'username'
      ])
      && request.resource.data.userId is string
      && request.resource.data.fullName is string
      && request.resource.data.role is string
      && request.resource.data.weekId is string
      && request.resource.data.availability is map;
    }

    // ----- Users -----
    match /users/{userId} {
      allow read: if isAdmin() || isSelf(userId);
      allow create: if isAdmin() || (isSelf(userId) && userCreateShapeValid());
      allow update: if isAdmin() || (isSelf(userId) && userSelfUpdateShapeValid());
      allow delete: if isAdmin();
    }

    // ----- Invite activation flow -----
    match /pendingUsers/{pendingId} {
      allow read, create, update, delete: if isAdmin();
    }

    // ----- Availability -----
    match /availabilities/{availabilityId} {
      allow read: if isAdmin() || (
        isSignedIn()
        && resource.data.userId is string
        && resource.data.userId == request.auth.uid
      );

      allow create, update: if isAdmin() || (
        isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && availabilityShapeValid()
      );

      allow delete: if isAdmin();
    }

    // ----- Schedules -----
    match /draftSchedules/{weekId} {
      allow read, write: if isAdmin();
    }

    match /publishedSchedules/{weekId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ----- Announcements -----
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Optional admin registry collection (if you prefer not to use custom claims)
    // match /adminUsers/{uid} {
    //   allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    //   allow write: if isAdmin();
    // }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
